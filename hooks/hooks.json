{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "test -f \"${CLAUDE_PLUGIN_ROOT}/src/read-cache.js\" || exit 0; node \"${CLAUDE_PLUGIN_ROOT}/src/read-cache.js\""
          },
          {
            "type": "command",
            "command": "test -f \"${CLAUDE_PLUGIN_ROOT}/src/context-shield.js\" || exit 0; node \"${CLAUDE_PLUGIN_ROOT}/src/context-shield.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "test -f \"${CLAUDE_PLUGIN_ROOT}/src/read-cache.js\" || exit 0; node \"${CLAUDE_PLUGIN_ROOT}/src/read-cache.js\""
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Glob|Grep|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "test -f \"${CLAUDE_PLUGIN_ROOT}/src/tracker.js\" || exit 0; node \"${CLAUDE_PLUGIN_ROOT}/src/tracker.js\""
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Glob|Grep|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "test -f \"${CLAUDE_PLUGIN_ROOT}/src/budget.js\" || exit 0; node \"${CLAUDE_PLUGIN_ROOT}/src/budget.js\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f \"${CLAUDE_PLUGIN_ROOT}/src/read-cache.js\" || exit 0; node \"${CLAUDE_PLUGIN_ROOT}/src/read-cache.js\""
          },
          {
            "type": "command",
            "command": "test -f \"${CLAUDE_PLUGIN_ROOT}/src/tracker.js\" || exit 0; node \"${CLAUDE_PLUGIN_ROOT}/src/tracker.js\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f \"${CLAUDE_PLUGIN_ROOT}/src/tracker.js\" || exit 0; node \"${CLAUDE_PLUGIN_ROOT}/src/tracker.js\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f \"${CLAUDE_PLUGIN_ROOT}/src/tracker.js\" || exit 0; node \"${CLAUDE_PLUGIN_ROOT}/src/tracker.js\""
          }
        ]
      }
    ]
  }
}
